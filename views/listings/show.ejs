<%- layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/css/show.css?v=20260222-1">
<link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
/>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h3><%= listing.title %></h3>

        <div class="card listing-card">
            <img src="<%= listing.image.url && listing.image.url.trim() !== '' ? listing.image.url : 'https://images.unsplash.com/photo-1505691938895-1758d7feb511' %>" class="card-img-top show-img"
                alt="<%= listing.title %> - <%= listing.price.toLocaleString('en-IN') %> per night">

            <div class="card-body">
                <p class="card-text">
                    <b><i>Hosted by <%= listing.owner ? listing.owner.username : "Host" %></i></b>
                    <br><br>
                    <%= listing.description %> <br>

                    <span class="fw-bold">
                        &#8377; <%= listing.price.toLocaleString("en-IN") %>
                    </span> / night <br>

                    <%= listing.location %>, <%= listing.country %>
                </p>
            </div>
        </div>

        <% if (currentUser && listing.owner && currentUser._id.equals(listing.owner._id)) { %>
            <div class="btns mb-5">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-0 edit-btn">Edit</a>
                <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
                    <button class="btn btn-dark offset-2">Delete</button>
                </form>
            </div>
        <% } %>

        <div class="map-section">
            <h4 class="map-heading">Location Map</h4>
            <div
                id="listing-map"
                data-title="<%= listing.title %>"
                data-location="<%= listing.location %>"
                data-country="<%= listing.country %>"></div>
        </div>

        <div class="unique-review-wrapper">
            <hr class="review-divider">

            <div class="review-form-container">
                <h4 class="review-heading">Leave a Review</h4>
                <% if (!currentUser) { %>
                    <p class="review-text">
                        Please <a href="/login">log in</a> to write a review.
                    </p>
                <% } else if (listing.owner && currentUser._id.equals(listing.owner._id)) { %>
                    <p class="review-text">You cannot review your own listing.</p>
                <% } else { %>
                    <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                        <div class="mb-3">
                            <label class="form-label review-label">Rating</label>
                            <fieldset class="starability-grow">
                                <input type="radio" id="rate5" name="review[rating]" value="5" required />
                                <label for="rate5" title="Amazing">5 stars</label>
                                <input type="radio" id="rate4" name="review[rating]" value="4" />
                                <label for="rate4" title="Very good">4 stars</label>
                                <input type="radio" id="rate3" name="review[rating]" value="3" />
                                <label for="rate3" title="Good">3 stars</label>
                                <input type="radio" id="rate2" name="review[rating]" value="2" />
                                <label for="rate2" title="Fair">2 stars</label>
                                <input type="radio" id="rate1" name="review[rating]" value="1" />
                                <label for="rate1" title="Poor">1 star</label>
                            </fieldset>
                        </div>

                        <div class="mb-3">
                            <label for="comment" class="form-label review-label">Comment</label>
                            <textarea
                                class="form-control review-textarea"
                                id="comment"
                                name="review[comment]"
                                rows="3"
                                placeholder="Share your experience..."
                                required></textarea>
                            <div class="invalid-feedback">Please write a review.</div>
                        </div>

                        <button class="btn review-btn">Submit Review</button>
                    </form>
                <% } %>
            </div>

            <hr class="review-divider">

            <h4 class="review-heading">All Reviews</h4>
            <% if (listing.reviews.length === 0) { %>
                <p class="review-text">No reviews yet. Be the first to leave one.</p>
            <% } else { %>
                <div class="reviews-grid">
                    <% for (let review of listing.reviews) { %>
                        <div class="card review-card">
                            <div class="card-body">
                                <div class="review-header">
                                    <div class="review-avatar">
                                        <%= review.author && review.author.username ? review.author.username.charAt(0).toUpperCase() : "U" %>
                                    </div>
                                    <div>
                                        <h5 class="review-author"><%= review.author && review.author.username ? review.author.username : "User" %></h5>
                                        <p class="review-date">Verified Stay</p>
                                    </div>
                                    <span class="review-rating-badge">&#9733; <%= review.rating %></span>
                                </div>
                                <p class="review-text"><%= review.comment %></p>

                                <% if (currentUser && review.author && currentUser._id.equals(review.author._id)) { %>
                                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="d-inline">
                                        <button class="btn btn-sm review-delete-btn">Delete</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""></script>
<script src="/js/showMap.js?v=20260228-1"></script>
