<% layout("/layouts/boilerplate") %>

<link rel="stylesheet" href="/css/listing.css?v=20260301-5">
<noscript>
    <style>
        #listing-skeletons { display: none !important; }
        #listing-grid { display: flex !important; }
    </style>
</noscript>

<div class="container-fluid mt-3 listing-page-shell">
    <div class="airbnb-filter-shell">
        <div class="airbnb-filters" id="airbnb-filters"></div>
        <label class="tax-toggle">
            <span>Display total before taxes</span>
            <input type="checkbox" id="tax-toggle-input">
            <span class="tax-toggle-slider"></span>
        </label>
    </div>

    <div class="airbnb-search-shell">
        <div class="filter-pill">
            <i class="fa-solid fa-earth-americas"></i>
            <select id="country-filter">
                <option value="">All countries</option>
            </select>
            <span class="filter-badge" id="country-filter-badge">0</span>
        </div>

        <div class="filter-pill">
            <i class="fa-solid fa-location-dot"></i>
            <select id="location-filter">
                <option value="">All locations</option>
            </select>
            <span class="filter-badge" id="location-filter-badge">0</span>
        </div>

        <div class="price-pill">
            <span>Min</span>
            <input id="min-price-filter" type="number" min="0" step="100">
            <span>Max</span>
            <input id="max-price-filter" type="number" min="0" step="100">
        </div>

        <button id="clear-filters-btn" type="button" class="clear-filters-btn">
            <i class="fa-solid fa-rotate-left"></i>
            <span>Reset</span>
            <span id="active-filters-badge" class="active-filters-badge">0</span>
        </button>
    </div>

    <div id="listing-skeletons" class="listing-skeletons">
        <% for (let i = 0; i < 8; i++) { %>
            <div class="skeleton-card">
                <div class="skeleton-image shimmer"></div>
                <div class="skeleton-lines">
                    <div class="skeleton-line shimmer"></div>
                    <div class="skeleton-line skeleton-line-short shimmer"></div>
                    <div class="skeleton-line skeleton-line-price shimmer"></div>
                </div>
            </div>
        <% } %>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 d-none" id="listing-grid">
        <% for (let listing of listings){ %>
            <div
                class="col mb-4 listing-item"
                data-title="<%= listing.title %>"
                data-location="<%= listing.location %>"
                data-country="<%= listing.country %>"
                data-price="<%= listing.price %>">
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card listing-card">
                        <div class="card-img-wrapper">
                            <img
                                src="<%= listing.image.url && listing.image.url.trim() !== '' ? listing.image.url : 'https://images.unsplash.com/photo-1505691938895-1758d7feb511' %>"
                                class="card-img-top"
                                alt="<%= listing.title %> - <%= listing.price.toLocaleString('en-IN') %> per night" />
                            <div class="card-heart">
                                <i class="fa-regular fa-heart"></i>
                            </div>
                        </div>

                        <div class="card-body">
                            <p class="card-text">
                                <b><%= listing.title %></b>
                                <span><%= listing.location %>, <%= listing.country %></span>
                                <br>
                                <span
                                    class="price-text price-value"
                                    data-base-price="<%= listing.price %>">&#8377; <%= listing.price.toLocaleString("en-IN") %></span>
                                <span class="tax-info">/ night</span>
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        <% } %>
    </div>

    <div id="no-listings-message" class="no-listings-message d-none">
        <i class="fa-regular fa-face-frown-open"></i>
        <h5>No stays match your filters</h5>
        <p>Try changing location, country, or price range.</p>
        <button type="button" id="no-results-reset-btn" class="no-results-reset-btn">Clear all filters</button>
    </div>
</div>

<script src="/js/index.js?v=20260301-2"></script>



