<% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/css/explore.css?v=20260308-2">
<link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
/>

<div class="explore-shell">
    <section class="explore-hero">
        <div>
            <p class="explore-kicker">Map explore</p>
            <h1>Browse stays by map</h1>
            <p>Pick a stay from the list or move across the map to understand where each property sits.</p>
        </div>
        <div class="explore-summary-strip">
            <span><i class="fa-solid fa-map-location-dot"></i> <%= listings.length %> mapped stays</span>
            <span><i class="fa-solid fa-star"></i> Compare by location first</span>
            <span><i class="fa-solid fa-house"></i> Open any stay in one click</span>
        </div>
    </section>

    <form method="GET" action="/listings/explore" class="explore-filter-form">
        <div class="explore-filter-dates">
            <div>
                <label for="exploreCheckIn">Check in</label>
                <input id="exploreCheckIn" type="date" name="checkIn" class="form-control" value="<%= initialFilters.checkIn || '' %>">
            </div>
            <div>
                <label for="exploreCheckOut">Check out</label>
                <input id="exploreCheckOut" type="date" name="checkOut" class="form-control" value="<%= initialFilters.checkOut || '' %>">
            </div>
        </div>
        <div class="explore-amenities">
            <% amenityOptions.forEach((amenity) => { %>
                <label class="explore-amenity-pill">
                    <input type="checkbox" name="amenities" value="<%= amenity %>" <%= (initialFilters.amenities || []).includes(amenity) ? "checked" : "" %>>
                    <span><%= amenity %></span>
                </label>
            <% }); %>
        </div>
        <button type="submit" class="explore-filter-btn">Apply filters</button>
    </form>

    <section class="explore-layout" data-explore-root data-listings='<%- JSON.stringify(listings.map((listing) => ({ id: listing._id, title: listing.title, location: listing.location, country: listing.country, price: listing.price, lat: listing.geo?.lat, lng: listing.geo?.lng, href: `/listings/${listing._id}` }))) %>'>
        <div class="explore-sidebar-shell">
            <div class="explore-sidebar-head">
                <h2>Mapped stays</h2>
                <p>Hover a card to focus the marker on the map.</p>
            </div>
            <div class="explore-sidebar">
            <% listings.forEach((listing) => { %>
                <a href="/listings/<%= listing._id %>" class="explore-card" data-listing-card data-lat="<%= listing.geo?.lat %>" data-lng="<%= listing.geo?.lng %>" data-id="<%= listing._id %>">
                    <img src="<%= listing.coverImage?.url || listing.image?.url %>" alt="<%= listing.title %>">
                    <div>
                        <h2><%= listing.title %></h2>
                        <p><%= listing.location %>, <%= listing.country %></p>
                        <span>&#8377; <%= Number(listing.price || 0).toLocaleString("en-IN") %> / night</span>
                    </div>
                </a>
            <% }); %>
            </div>
        </div>
        <div class="explore-map" id="explore-map"></div>
    </section>
</div>

<script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""></script>
<script src="/js/exploreMap.js?v=20260308-1"></script>
